VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# VITE_BACKEND_URL is used when the frontend is deployed separately from the backend.
# For example, if you deploy the frontend to Vercel and the backend to Render.
# If left empty, the socket will connect to the same origin (useful for full-stack deployments).
VITE_BACKEND_URL=
